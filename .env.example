# =====================================================
# WHATSAPP (Meta Cloud API)
# =====================================================
# Get from Meta Developer Console → WhatsApp → API Setup
WHATSAPP_TOKEN=your_access_token_here
WHATSAPP_PHONE_ID=your_phone_number_id_here
# Any string you choose for webhook verification
WHATSAPP_VERIFY_TOKEN=finflow_verify_2026

# =====================================================
# AI SERVICES
# =====================================================
# Sarvam AI key for NLP text parsing (dashboard.sarvam.ai)
SARVAM_API_KEY=sk_your_sarvam_key_here
# Google Gemini API key for receipt photo scanning (aistudio.google.com)
GEMINI_API_KEY=your_gemini_api_key_here

# =====================================================
# SUPABASE (PostgreSQL Database)
# =====================================================
# Supabase project URL (Settings → API)
SUPABASE_URL=https://your-project.supabase.co
# Supabase service role key (Settings → API → service_role)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# =====================================================
# APP INTEGRATION
# =====================================================
# Your Next.js app URL (Vercel deployment)
APP_URL=https://your-app.vercel.app
# Shared secret between bot and app for budget alert API
WEBHOOK_SECRET=your_shared_secret_here

# =====================================================
# SERVER
# =====================================================
# Port for the Express server (Render sets this automatically)
PORT=3000
